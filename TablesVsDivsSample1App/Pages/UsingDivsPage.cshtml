@page
@using Microsoft.CodeAnalysis.Scripting
@model TablesVsDivsSample1App.Pages.UsingDivsPageModel
@inject IHttpContextAccessor HttpContextAccessor
@{
}
<h1  class="fs-4 mb-3">Customers (Divs with Bootstrap 5)</h1>

<div class="container">

    <!-- Sticky Header visible md+ only -->
    <div class="row fw-bold py-2 bg-dark text-white sticky-top shadow-sm z-1 d-none d-md-flex">
        <div class="col-md-3">Company</div>
        <div class="col-md-2">Contact Type</div>
        <div class="col-md-2">Contact Name</div>
        <div class="col-md-1">Country</div>
        <div class="col-md-2">Join Date</div>
        <div class="col-md-2 text-end">Actions</div>
    </div>

    <!-- Data Rows with Zebra Style + Mobile Labels -->
    @for (int index = 0; index < Model.Customers.Count; index++)
    {
        var item = Model.Customers[index];
        var rowClass = (index % 2 == 0) ? "bg-light" : "";

        <div class="row border-bottom py-3 align-items-center @rowClass">
            <div class="col-12 col-md-3">
                <span class="d-md-none fw-semibold me-1">Company:</span>
                @item.Company
            </div>
            <div class="col-12 col-md-2">
                <span class="d-md-none fw-semibold me-1">Contact Type:</span>
                @item.ContactType
            </div>
            <div class="col-12 col-md-2">
                <span class="d-md-none fw-semibold me-1">Contact Name:</span>
                @item.ContactName
            </div>
            <div class="col-12 col-md-1">
                <span class="d-md-none fw-semibold me-1">Country:</span>
                @item.Country
            </div>
            <div class="col-12 col-md-2">
                <span class="d-md-none fw-semibold me-1">Join Date:</span>
                @item.JoinDate.ToString("MM/dd/yyyy")
            </div>

            <div class="col-12 col-md-2 d-flex justify-content-start justify-content-md-end gap-2 mt-2 mt-md-0">
                <a asp-page="./CustomerEditPage"
                   asp-route-id="@item.Id"
                   asp-route-returnUrl="@($"{Request.Path}{Request.QueryString}")"
                   class="btn btn-sm btn-outline-primary"
                   title="Edit">
                    <i class="bi bi-pencil"></i>
                </a>
                <a asp-page="./Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-dark" title="Details">
                    <i class="bi bi-eye"></i>
                </a>
                <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="Delete">
                    <i class="bi bi-trash"></i>
                </a>
            </div>
        </div>
    }
    

    <div class="row mb-2 mt-4">
        <div class="col-12 text-center">
            <button id="backHome" class="btn btn-outline-dark">
                <span class="me-2">Top</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-up-circle" viewBox="0 0 16 16">
                    <path fill-rule="evenodd" d="M1 8a7 7 0 1 0 14 0A7 7 0 0 0 1 8m15 0A8 8 0 1 1 0 8a8 8 0 0 1 16 0m-7.5 3.5a.5.5 0 0 1-1 0V5.707L5.354 7.854a.5.5 0 1 1-.708-.708l3-3a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1-.708.708L8.5 5.707z" />
                </svg>
            </button>
        </div>
    </div>
</div>

<script type="text/javascript">
    document.getElementById("backHome").addEventListener("click", function () {
        window.scrollTo({ top: 0, behavior: 'instant' });
    });
</script>