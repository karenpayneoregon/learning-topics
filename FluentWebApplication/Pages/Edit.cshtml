@page
@model FluentWebApplication.Pages.EditModel

@{
    ViewData["Title"] = "Edit";
}

<style>
    .required::after 
    {
/*        content: " *";
        font-weight: bold;
        color: red; */
    }
    .validate-text {
        color: crimson;
        font-weight: bold
    }
</style>

<div class="alert alert-primary" role="alert">
    Edit
</div>

<div class="row">
    <div class="col-md-4">
        <form method="post" role="form">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" asp-for="Person.PersonId"/>

            <div class="form-group">

                <div class="d-flex justify-content-between">
                    <div>
                        <label asp-for="Person.FirstName" class="required"></label>
                    </div>
                    @*                     <div>
                        <span style="color: crimson;font-weight: bold">Required</span>
                    </div> *@
           
                </div>

                <input asp-for="Person.FirstName"
                       class="form-control mb-2"
                       placeholder="Enter first name"
                       aria-label="First name" required/>

                <span asp-validation-for="Person.FirstName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <div class="d-flex justify-content-between">
                    <div>
                        <label asp-for="Person.LastName" class="required"></label>
                    </div>
        
                </div>

                <input asp-for="Person.LastName" 
                       class="form-control mb-2" 
                       placeholder="Enter last name" 
                       aria-label="Last name" required />

                <span asp-validation-for="Person.LastName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <div class="d-flex justify-content-between">

                    <div>
                        <label asp-for="Person.EmailAddress" class="required"></label>
                    </div>

                    
                </div>

                <input asp-for="Person.EmailAddress" 
                       class="form-control" style="width: 300px"
                       placeholder="Enter your email address" 
                       aria-label="Email address" required />

                <span asp-validation-for="Person.EmailAddress" class="text-danger"></span>

            </div>

@*             <div class="form-group mt-2">
                <input type="submit" value="Save" role="button" class="btn btn-primary mt-2"/>
            </div> *@
            <div class="row">
                <div class="col-auto">
                    <input type="submit" value="Save" role="button" class="btn btn-primary mt-2" />
                </div>
                <div class="col-auto">
                    <a asp-page="./List" class="btn btn-primary mt-2">Back to List</a>
                </div>
            </div>
        </form>
    </div>
</div>



@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
