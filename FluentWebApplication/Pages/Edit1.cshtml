@page
@model FluentWebApplication.Pages.Edit1Model

@{
    ViewData["Title"] = "Edit Person";
}

<style>
    .form-label::after{
        content: " *";
        color: crimson;
        font-weight: 700;
    }
</style>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header">
                    <h1 class="h4 mb-0">Edit Person</h1>
                </div>

                <div class="card-body">
                    <form method="post" class="needs-validation" novalidate>
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <input type="hidden" asp-for="Person.PersonId" />

                        <div class="row g-3">
                            <div class="col-12 col-md-6">
                                <label asp-for="Person.FirstName" class="form-label"></label>
                                <input asp-for="Person.FirstName" class="form-control" />
                                <span asp-validation-for="Person.FirstName" class="text-danger"></span>
                            </div>

                            <div class="col-12 col-md-6">
                                <label asp-for="Person.LastName" class="form-label"></label>
                                <input asp-for="Person.LastName" class="form-control" />
                                <span asp-validation-for="Person.LastName" class="text-danger"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="Person.EmailAddress" class="form-label"></label>
                                <input asp-for="Person.EmailAddress" class="form-control" />
                                <span asp-validation-for="Person.EmailAddress" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="d-flex gap-2 justify-content-end mt-4">
                            <a asp-page="./List" class="btn btn-outline-secondary">Cancel</a>
                            <button type="submit" class="btn btn-primary">Save</button>
                        </div>
                    </form>
                </div>

                <div class="card-footer text-muted small">
                    Person ID: @Model.Person.PersonId
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}